@baseUrl = http://localhost:3000/api/contacts

### Get all contacts
GET {{baseUrl}}
Content-Type: application/json


### Get contact by ID
GET {{baseUrl}}/1
Content-Type: application/json

{
    "name": "Jane Doe",
    "email": "jane@example.com",
    "phone": "123456789"
}

### Update a contact
PUT {{baseUrl}}/1
Content-Type: application/json

{
    "name
}